# MERUSAKA Security System - Environment Variables
# Copy this file to .env and update the values

# Server port (default: 3000)
PORT=3000

# JWT Secret - WAJIB DIGANTI di production!
# Gunakan string acak yang panjang dan aman
JWT_SECRET=merusaka-hotel-secret-key-GANTI-INI-di-production

# Path database SQLite (default: ./data/merusaka.db)
DB_PATH=./data/merusaka.db

# CORS Origins yang diizinkan (kosongkan untuk allow all - tidak direkomendasikan di production)
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
